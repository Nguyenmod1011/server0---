# ============================================================
# .htaccess – Bảo mật thư mục gốc
# ============================================================

# Chặn truy cập trực tiếp vào config.php
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# Chặn truy cập install.php sau khi cài xong (KHUYẾN NGHỊ XÓA FILE NÀY)
<Files "install.php">
    Order allow,deny
    Deny from all
</Files>

# Chỉ cho phép POST vào api.php (optional - bỏ comment nếu muốn)
# <Files "api.php">
#     <LimitExcept POST OPTIONS>
#         Deny from all
#     </LimitExcept>
# </Files>

# Bảo mật header
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "DENY"
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Tắt directory listing
Options -Indexes

# Chặn file nhạy cảm
<FilesMatch "\.(sql|log|bak|sh|env)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Force HTTPS (bỏ comment khi đã có SSL)
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Error pages
ErrorDocument 403 /admin/login.php
ErrorDocument 404 /admin/login.php
